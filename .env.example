# ============================================================
# AgentClaw — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ----- Firebase (Data Persistence) -----
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ----- JWT Auth -----
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="24h"

# ----- MikroTik Defaults -----
MIKROTIK_API_PORT=8728
MIKROTIK_DEFAULT_USER="admin"
MIKROTIK_DEFAULT_PASSWORD=""

# ----- SMTP / Email -----
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="AgentClaw <no-reply@agentclaw.com>"

# ----- WhatsApp (Meta Business Cloud API) -----
WHATSAPP_PHONE_ID="your-whatsapp-phone-id"
WHATSAPP_TOKEN="your-meta-bearer-token"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"

# ----- Stripe -----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ----- EcoCash (placeholder) -----
ECOCASH_MERCHANT_CODE=""
ECOCASH_API_URL="https://api.ecocash.co.zw/v1"
ECOCASH_API_KEY=""

# ----- ZIPIT (placeholder) -----
ZIPIT_API_URL="https://api.zipit.co.zw/v1"
ZIPIT_API_KEY=""

# ----- Printer -----
PRINTER_TYPE="network"          # "usb" | "network"
PRINTER_ADDRESS="192.168.1.100" # network printer IP
PRINTER_PORT=9100
PRINTER_USB_VID="0x04b8"        # Epson USB VID (example)
PRINTER_USB_PID="0x0e15"        # Epson TM-T20 PID

# ----- API Server -----
API_PORT=4000
API_BASE_URL="http://localhost:4000"

# ----- POS Dashboard -----
NEXT_PUBLIC_API_URL="http://localhost:4000"
POS_PORT=3000

# ----- E-Commerce -----
ECOM_PORT=3001
NEXT_PUBLIC_ECOM_API_URL="http://localhost:4000"

# ----- Predictive Agent -----
PREDICTIVE_LOAD_THRESHOLD=80    # Alert when hotspot load > 80%
PREDICTIVE_POLL_INTERVAL=300000 # Poll every 5 minutes (ms)
