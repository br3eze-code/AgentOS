# ============================================================
# AgentClaw — Environment Variables
# ============================================================

# ----- Firebase (Data Persistence) -----
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_DATABASE_URL=""

# ----- JWT Auth -----
JWT_SECRET="agentclaw-development-secret-change-in-prod"
JWT_EXPIRES_IN="24h"

# ----- MikroTik Defaults -----
MIKROTIK_API_PORT=8728
MIKROTIK_DEFAULT_USER="admin"
MIKROTIK_DEFAULT_PASSWORD="admin123"

# ----- SMTP / Email -----
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="AgentClaw <no-reply@agentclaw.com>"

# ----- WhatsApp (Meta Business Cloud API) -----
WHATSAPP_PHONE_ID="your-whatsapp-phone-id"
WHATSAPP_TOKEN="your-meta-bearer-token"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"

# ----- Stripe -----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ----- EcoCash (placeholder) -----
ECOCASH_MERCHANT_CODE=""
ECOCASH_API_URL="https://api.ecocash.co.zw/v1"
ECOCASH_API_KEY=""

# ----- ZIPIT (placeholder) -----
ZIPIT_API_URL="https://api.zipit.co.zw/v1"
ZIPIT_API_KEY=""

# ----- Printer -----
PRINTER_TYPE="network"
PRINTER_ADDRESS="192.168.1.100"
PRINTER_PORT=9100
PRINTER_USB_VID="0x04b8"
PRINTER_USB_PID="0x0e15"

# ----- API Server -----
API_PORT=4000
API_BASE_URL="http://localhost:4000"

# ----- POS Dashboard -----
NEXT_PUBLIC_API_URL="http://localhost:4000"
POS_PORT=3000

# ----- E-Commerce -----
ECOM_PORT=3001
NEXT_PUBLIC_ECOM_API_URL="http://localhost:4000"

# ----- Predictive Agent -----
PREDICTIVE_LOAD_THRESHOLD=80
PREDICTIVE_POLL_INTERVAL=300000
